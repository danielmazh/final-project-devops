[flake8]
max-line-length = 120
exclude =
    cli/tests/,
    .venv/,
    .terraform/,
    engine/

# Ignore upstream code style conventions:
#   E302 / E303 – blank lines (upstream uses different conventions)
#   E402        – module-level imports not at top (VERSION constant precedes imports)
#   F401        – unused imports (upstream keeps them for API compatibility)
#   F841        – local variable assigned but never used (upstream scaffolding)
#   F541        – f-string without placeholders (upstream templates)
#   W293        – whitespace in blank lines (upstream style)
#   W291        – trailing whitespace (upstream style)
extend-ignore = E302,E303,E402,F401,F841,F541,W293,W291,E501
