%% File: .cursor/diagrams/001_Architecture_Overview.mmd
%% Title: High-Level System Architecture Overview
%% Pattern: Hub-and-Spoke / Platform Architecture
%% Scope: All system components, external services, and data flows
%% Ref: .instructions/final_project.md (full project scope including RAG bonus)

flowchart TB
    subgraph SourceControl ["Source Control (GitHub)"]
        AppRepo["seyoawe-community\n(Application Repo)"]
        InfraRepo["final-project-devops\n(Infrastructure Repo)"]
    end

    subgraph CICD ["CI/CD Layer (Jenkins on EKS)"]
        JenkinsCtrl["Jenkins Controller"]
        EngineCI["Engine CI\nPipeline"]
        CLICI["CLI CI\nPipeline"]
        CDPipeline["CD Pipeline"]
    end

    subgraph VersionControl ["Version Coupling"]
        VersionFile["VERSION file\n(single source of truth)"]
        ChangeDetect["Change Detection\n(scripts/version.sh)"]
    end

    subgraph Registry ["Container Registry"]
        DockerHub["Docker Hub"]
        EngineImage["seyoawe-engine\nimage"]
        CLIImage["seyoawe-cli\nimage"]
    end

    subgraph IaC ["Infrastructure as Code"]
        Terraform["Terraform\n(AWS Provisioning)"]
        Ansible["Ansible\n(Config Management)"]
    end

    subgraph AWSCloud ["AWS Cloud"]
        subgraph VPC ["VPC (10.0.0.0/16)"]
            subgraph EKSCluster ["EKS Cluster"]
                EngineStatefulSet["Engine\nStatefulSet"]
                JenkinsPod["Jenkins\nPods"]
                PrometheusStack["Prometheus\nStack"]
                GrafanaPod["Grafana"]
                RAGPod["RAG Service\n(Bonus)"]
            end
        end
        S3["S3\n(TF State)"]
        DynamoDB["DynamoDB\n(State Lock)"]
        IAM["IAM\nRoles"]
    end

    subgraph Observability ["Observability"]
        Metrics["Metrics\nCollection"]
        Dashboards["Grafana\nDashboards"]
        Alerts["Alert\nRules"]
    end

    subgraph RAGExtension ["AI RAG Extension (Bonus)"]
        VectorStore["Vector Store\n(Embeddings)"]
        LLMBackend["LLM Backend\n(AI Service)"]
        ChatInterface["Chatbot\nInterface"]
    end

    AppRepo -->|"webhook"| JenkinsCtrl
    InfraRepo -->|"webhook"| JenkinsCtrl
    JenkinsCtrl --> ChangeDetect
    ChangeDetect --> VersionFile
    VersionFile --> EngineCI
    VersionFile --> CLICI
    JenkinsCtrl --> CDPipeline

    EngineCI -->|"build + push"| EngineImage
    CLICI -->|"build + push"| CLIImage
    EngineImage --> DockerHub
    CLIImage --> DockerHub

    CDPipeline --> Terraform
    CDPipeline --> Ansible
    Terraform -->|"provision"| VPC
    Terraform -->|"state"| S3
    Terraform -->|"lock"| DynamoDB
    Terraform -->|"create"| IAM
    Ansible -->|"configure"| EKSCluster

    DockerHub -->|"pull"| EngineStatefulSet

    EngineStatefulSet --> Metrics
    JenkinsPod --> Metrics
    Metrics --> PrometheusStack
    PrometheusStack --> GrafanaPod
    GrafanaPod --> Dashboards
    PrometheusStack --> Alerts

    EngineStatefulSet -->|"workflow logs\n+ docs"| RAGPod
    RAGPod --> VectorStore
    VectorStore --> LLMBackend
    LLMBackend -->|"troubleshooting\nassistance"| ChatInterface
